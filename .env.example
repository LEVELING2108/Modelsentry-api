NODE_ENV=development
PORT=3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/ml_serving_db

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# API Key (master key for seeding)
MASTER_API_KEY=sk-master-dev-key-change-in-production

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ML Model Config
MODEL_V1_WEIGHT=0.8
MODEL_V2_WEIGHT=0.2
MODEL_TIMEOUT_MS=5000
HF_API_KEY=
MODEL_V1_ID=distilbert-base-uncased-finetuned-sst-2-english
MODEL_V2_ID=cardiffnlp/twitter-roberta-base-sentiment-latest

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Redis Caching
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL_SEC=86400
REDIS_ENABLED=true

# Upstream Fallback ML Providers
# Options: openai, gemini, self-hosted, or leave empty
FALLBACK_PROVIDER=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
SELF_HOSTED_URL=
SELF_HOSTED_API_KEY=

